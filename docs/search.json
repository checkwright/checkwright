---
layout: null
---
[
  {%- assign entries = site.pages | where_exp: "p", "p.title" -%}
  {%- for p in entries -%}
    {
      "title": {{ p.title | default: p.name | jsonify }},
      "url": {{ p.url | relative_url | jsonify }},
      "parent": {{ p.nav_parent | default: p.nav_id | default: "" | jsonify }},
      "content": {{ p.content | strip_html | normalize_whitespace | truncatewords: 80 | jsonify }}
    }{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
]
