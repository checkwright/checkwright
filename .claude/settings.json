{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/bash-guard.sh"
          }
        ]
      },
      {
        "matcher": "ScheduleWakeup|CronCreate",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/wakeup-guard.sh"
          }
        ]
      }
    ]
  }
}
